{
	"name": "Ollama + Claude CLI Studio",
	"image": "mcr.microsoft.com/devcontainers/base:${templateOption:imageVariant}",
	"remoteUser": "vscode",
	"containerEnv": {
		"OLLAMA_HOST": "http://host.docker.internal:11434",
		"CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
	},
	"features": {
		"ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/node:2.1.0": {
			"version": "20"
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-backend:1": {
			"authToken": "ollama",
			"models": "${templateOption:modelMap}",
			"logLevel": "error"
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-hooks:1": {},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-privacy:1": {
			"disableTelemetry": true,
			"disableErrorReporting": true,
			"disableFeedback": true,
			"disableUpdates": true
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-rules:1": {
			"enforceSafety": true,
			"standardizeWorkflow": true,
			"protectGit": true,
			"preferPythonTooling": false
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-skills:1": {
			"installEngineering": true,
			"installProductivity": true,
			"installMisc": false,
			"installPersonal": false
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-plugins:1": {
			"enableRalphLoop": true,
			"skipOnFailure": true
		},
		"ghcr.io/devcontainers/features/docker-in-docker:4.0.0": {
			"moby": "false",
			"dockerDashComposeVersion": "v2"
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-mcp-servers:1": {
			"enableGithub": true,
			"enableFilesystem": true
		},
		"ghcr.io/mrrobot0985/devcontainer-features/container-firewall:1": {
			"services": "claude-code,docker"
		},
		"ghcr.io/srzstephen/devcontainer-features/nvidia-container-toolkit:1": {},
		"ghcr.io/mrrobot0985/devcontainer-features/non-root-enforcer:1": {},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-audit-log:1": {},
		"ghcr.io/mrrobot0985/devcontainer-features/ai-agent-sandbox:1": {
			"preset": "moderate",
			"failOnWarning": false
		}
	},
	"runArgs": [
		"--add-host=host.docker.internal:host-gateway",
		"--gpus=all"
	],
	"forwardPorts": [
		11434
	],
	"mounts": [
		"source=claude-cli-config-${devcontainerId},target=/home/vscode/.claude,type=volume"
	],
	"postCreateCommand": "bash .devcontainer/bootstrap.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"github.copilot",
				"github.copilot-chat"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash",
				"editor.formatOnSave": true
			}
		}
	}
}
