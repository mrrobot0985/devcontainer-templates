{
	"name": "Ollama + Claude CLI (CPU)",
	"image": "mcr.microsoft.com/devcontainers/base:${templateOption:imageVariant}",
	"remoteUser": "vscode",
	"containerEnv": {
		"OLLAMA_HOST": "http://host.docker.internal:11434",
		"CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
	},
	"features": {
		"ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/node:2.1.0": {
			"version": "20"
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-backend:0": {
			"authToken": "ollama",
			"models": "${templateOption:modelMap}",
			"logLevel": "error"
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-privacy:0": {
			"disableTelemetry": true,
			"disableErrorReporting": true,
			"disableFeedback": true,
			"disableUpdates": true
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-plugins:0": {},
		"ghcr.io/mrrobot0985/devcontainer-features/container-firewall:0": {}
	},
	"runArgs": [
		"--add-host=host.docker.internal:host-gateway"
	],
	"forwardPorts": [
		11434
	],
	"mounts": [
		"source=claude-cli-config-${devcontainerId},target=/home/vscode/.claude,type=volume"
	],
	"postCreateCommand": "bash .devcontainer/bootstrap.sh"
}
