{
	"name": "OpenCode CLI",
	"image": "mcr.microsoft.com/devcontainers/base:${templateOption:imageVariant}",
	"remoteUser": "vscode",
	"features": {
		"ghcr.io/sliekens/devcontainer-features/opencode:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/node:2.1.0": {
			"version": "20"
		},
		"ghcr.io/mrrobot0985/devcontainer-features/container-firewall:1": {
			"services": "github,npm",
			"extraDomains": "opencode.ai,api.opencode.ai,models.dev"
		},
		"ghcr.io/mrrobot0985/devcontainer-features/non-root-enforcer:1": {},
		"ghcr.io/mrrobot0985/devcontainer-features/ai-agent-sandbox:1": {
			"preset": "moderate",
			"failOnWarning": false
		}
	},
	"mounts": [
		"source=opencode-cli-data-${devcontainerId},target=/home/vscode/.local/share/opencode,type=volume",
		"source=opencode-cli-config-${devcontainerId},target=/home/vscode/.config/opencode,type=volume"
	],
	"initializeCommand": "mkdir -p \"${localEnv:HOME}/.local/share/opencode\" \"${localEnv:HOME}/.config/opencode\"",
	"postCreateCommand": "bash .devcontainer/bootstrap.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"sst-dev.opencode",
				"github.copilot",
				"github.copilot-chat"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash",
				"editor.formatOnSave": true
			}
		}
	}
}
