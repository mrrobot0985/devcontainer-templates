{
	"name": "Ollama + Claude CLI + Sandcastle Studio",
	"image": "mcr.microsoft.com/devcontainers/base:${templateOption:imageVariant}",
	"remoteUser": "vscode",
	"containerEnv": {
		"OLLAMA_HOST": "http://host.docker.internal:11434",
		"CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
	},
	"features": {
		"ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/node:2.1.0": {
			"version": "20"
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-backend:0": {
			"authToken": "ollama",
			"logLevel": "error"
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-hooks:0": {},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-privacy:0": {
			"disableTelemetry": true,
			"disableErrorReporting": true,
			"disableFeedback": true,
			"disableUpdates": true
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-rules:0": {
			"enforceSafety": true,
			"standardizeWorkflow": true,
			"protectGit": true,
			"preferPythonTooling": false
		},
		"ghcr.io/mrrobot0985/devcontainer-features/claude-code-skills:0": {
			"installEngineering": true,
			"installProductivity": true,
			"installMisc": false,
			"installPersonal": false
		},
		"ghcr.io/devcontainers/features/docker-in-docker:4.0.0": {
			"moby": "false",
			"dockerDashComposeVersion": "v2"
		},
		"ghcr.io/mrrobot0985/devcontainer-features/nvidia-container-toolkit:0": {
			"enable": false,
			"defaultRuntime": false,
			"restartDockerd": true
		}
	},
	"runArgs": [
		"--add-host=host.docker.internal:host-gateway",
		"--gpus=all"
	],
	"forwardPorts": [
		11434
	],
	"mounts": [
		"source=claude-cli-config-${devcontainerId},target=/home/vscode/.claude,type=volume"
	],
	"postCreateCommand": "bash .devcontainer/bootstrap.sh"
}
