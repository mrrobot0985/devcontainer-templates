#!/bin/bash
set -euo pipefail

# Pre-commit hook: ensure template READMEs stay in sync with devcontainer-template.json metadata.
# Install with: git config core.hooksPath .githooks

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

# Generate any missing READMEs from devcontainer-template.json files.
python3 scripts/generate-template-readmes.py

# Fail fast if the create-devcontainer template registry is out of sync.
if [ -f "packages/create-devcontainer/src/templates.ts" ]; then
    if ! npx tsx scripts/sync-template-registry.ts 2>/dev/null; then
        echo ""
        echo "ERROR: Template registry is out of sync."
        echo "Run the following to regenerate it:"
        echo "  npx tsx scripts/sync-template-registry.ts --write"
        echo "  git add packages/create-devcontainer/src/templates.ts"
        exit 1
    fi
fi

# If new READMEs were created (untracked), stage them and abort so the user reviews.
if git ls-files --others --exclude-standard | grep -qE '^src/.*/README\.md$'; then
    echo ""
    echo "Generated new template README(s):"
    git ls-files --others --exclude-standard | grep -E '^src/.*/README\.md$'
    echo ""
    echo "Review the generated files, then stage and commit again:"
    echo "  git add src/*/README.md"
    echo "  git commit -m '...'"
    exit 1
fi

# Warn when devcontainer-template.json is staged but README.md is not.
# We warn instead of failing because READMEs often contain manual
# enhancements beyond what the generator produces.
STAGED_JSONS=$(git diff --cached --name-only --diff-filter=ACM | grep 'devcontainer-template\.json$' || true)
if [ -n "$STAGED_JSONS" ]; then
    MISSING_README_UPDATES=""
    for json_file in $STAGED_JSONS; do
        readme_file="$(dirname "$json_file")/README.md"
        if ! git diff --cached --name-only | grep -Fxq "$readme_file"; then
            MISSING_README_UPDATES="${MISSING_README_UPDATES}\n  - ${readme_file} (not staged with ${json_file})"
        fi
    done
    if [ -n "$MISSING_README_UPDATES" ]; then
        echo ""
        echo "WARNING: The following devcontainer-template.json files are staged"
        echo "but their README.md counterparts are not. Consider updating them:"
        printf '%b\n' "$MISSING_README_UPDATES"
        echo ""
        # Non-fatal: manual README content is common.
    fi
fi

# --- Docs markdown formatting check ---
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^docs/.*\.md$' || true)
if [ -n "$STAGED_MD" ]; then
    if command -v uv >/dev/null 2>&1; then
        if ! uvx --with mdformat-gfm mdformat --check $STAGED_MD; then
            echo ""
            echo "ERROR: Staged markdown files in docs/ are not properly formatted."
            echo "Run the following to fix them:"
            echo "  uvx --with mdformat-gfm mdformat $STAGED_MD"
            echo "Then stage the changes and commit again."
            exit 1
        fi
    elif command -v mdformat >/dev/null 2>&1; then
        if ! mdformat --check $STAGED_MD; then
            echo ""
            echo "ERROR: Staged markdown files in docs/ are not properly formatted."
            echo "Run the following to fix them:"
            echo "  mdformat $STAGED_MD"
            echo "Then stage the changes and commit again."
            exit 1
        fi
    else
        echo ""
        echo "WARNING: mdformat is not installed. Skipping markdown format check."
        echo "Install it with: uv tool install mdformat-gfm"
        echo ""
    fi
fi

exit 0
